<script type="text/template" id="job-template">
  <% jobs.each(function( job ) { %>
    <tr data-id="<% print(job.get('id')); %>" data-type="<% print(job.get('type')); %>">
      <td class="jobName">
        <% if (typeof job.get('job') !== 'string') { %>
          <% if (typeof AdGmsEstimateElementsManager == 'object' && job.get('type') == AdGmsEstimateElementsManager.getInstance().customTaskTypeName) { %>
          <input class="editable" type="text" value="<% print(escapeDoubleQuotes(job.get('description'))); %>"/>
          <i class="fa fa-pencil" aria-hidden="true"></i>
          <% } else { %>
            <span class="est-type" type="job" data-repair-id="<% print(job.get('repair_id')); %>"><% print(job.get('description')); %><two class="hidden"><sup> **</sup></two></span>
            <div class="estimate-sub-content">
              <ul class="inclusive-jobs">
                <% _.each(job.get('job'), function(line) { %>
                  <li data-repair-id="<%= line.repair_id %>"><%= line.name %><one class="hidden"><sup> *</sup></one><two class="hidden"><sup> **</sup></two></li>
                <% }); %>
              </ul>
            </div>
          <% } %>
        <% } else {%>
          <% print(job.get('job')); %>
        <% } %>
      </td>
      <td class="jobRate">
          <input class="editable" type="text" value="<% print(job.get('hourlyRate')); %>" placeholder="0"/>
          <i class="fa fa-pencil" aria-hidden="true"></i>
      </td>
      <td class="jobTime">
          <input class="editable" type="text" value="<% print(job.get('time')); %>" />
          <i class="fa fa-pencil" aria-hidden="true"></i>
      </td>
              <td class="job vatSelect hide-important">
            <a class="checkbox-link <% if (job.get('includeInVat') || job.get('includeInVat')==null) { %>selected<% } %>" href="#" onClick="addVatSelect(this);">
                <i class="fa fa-square-o" aria-hidden="true"></i>
                <i class="fa fa-check-square-o" aria-hidden="true"></i>
            </a></td>
            <td class="jobTotal">
        <span class="total"><% print(parseFloat(job.get('hourlyRateTotal')).toFixed(2)); %></span>
        <span class="delete-row-icon" title="Radera arbetsuppgift">
            <i class="fa fa-times-circle" aria-hidden="true"></i>
        </span>
      </td>
    </tr>
  <% }); %>
  <% if (jobs.length == 0) { %>
    <tr><td></td><td></td></tr>
  <% }; %>
</script>

<script type="text/template" id="time-template">
  <tr class="tfoot">
    <td><i class="fa fa-plus" aria-hidden="true"></i></td>
    <td class="right">
              <span class="total">Summa</span>&nbsp;
          </td>
    <td>
      <% print(jobs.totalTime()); %>
    </td>
        <td class="emptyTable hide-important"></td>
        <td>
      <% print(jobs.totalHourlyRate()); %>
    </td>
  </tr>
</script>

<script type="text/template" id="parts-template">

  <% parts.each(function( part ) { %>
    <tr data-type="part" data-id="<% print(part.get('id')); %>">
      <td class="partName">
        <% if (typeof AdGmsEstimateElementsManager == 'object' && part.get('type') == AdGmsEstimateElementsManager.getInstance().customPartTypeName) { %>
          <input class="editable" type="text" value="<% print(escapeDoubleQuotes(part.get('description'))); %>" />
          <i class="fa fa-pencil" aria-hidden="true"></i>
        <% } else { %>
          <% if (part.get('note')) { %>
                          <div class="est-type" name="est-type1"> <a href="#" class="noteTrigger"><% print(part.get('description') + ' - ' + part.get('service_operation_action')); %></a> <p class="showhide-icon-group"><span class="showhide-icon-trigger notes"></span></p> </div>
            <% } else { %>
                <div class="est-type" name="est-type1"> <% print(part.get('description'));
                  if (part.get('service_operation_action') != undefined) { print(' - ' + part.get('service_operation_action')); } %></div>
                      <% } %>
        <% } %>
      </td>

      <td class="unitPrice">
          <input class="editable" type="text" value="<% print(part.get('unitPrice')); %>" placeholder="0" />
          <i class="fa fa-pencil" aria-hidden="true"></i>
      </td>
      <td class="partQty">
          <input class="editable" type="text" value="<% print(part.get('partQty')); %>" placeholder="1" />
          <i class="fa fa-pencil" aria-hidden="true"></i>
      </td>
              <td class="part vatSelect hide-important">
            <a class="checkbox-link <% if (part.get('includeInVat') || part.get('includeInVat')==null) { %>selected<% } %>" href="#" onClick="addVatSelect(this);">
                <i class="fa fa-square-o" aria-hidden="true"></i>
                <i class="fa fa-check-square-o" aria-hidden="true"></i>
            </a></td>
      
      <td class="partTotal">
        <span class="total"><% print(parseFloat(part.get('priceTotal')).toFixed(2)); %></span>
        <span class="delete-row-icon" title="Ta bort del">
            <i class="fa fa-times-circle" aria-hidden="true"></i>
        </span>
      </td>
<!--      <td><% print(part.get('qty')); %><span class="delete-row-icon" title="Ta bort del">Ta bort del</span></td> -->
    </tr>
      <% if (part.get('note')) { %>
        <tr class="showhide-section hidden">
          <td colspan="4">
            <div class="note" >
              <% print(part.get('note')) %>
            </div>
          </td>
        </tr>
      <% } %>
  <% }); %>
  <% if (parts.length == 0) { %>
  <tr><td></td><td></td></tr>
  <% }; %>
</script>


